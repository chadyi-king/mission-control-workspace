[Unit]
Description=Helios v2 - Mission Control Engineer
After=network.target

[Service]
Type=simple
WorkingDirectory=/home/chad-yi/.openclaw/workspace/agents/helios
ExecStart=/home/chad-yi/.venv/bin/python /home/chad-yi/.openclaw/workspace/agents/helios/helios-v2.py
Restart=always
RestartSec=30
StandardOutput=append:/home/chad-yi/.openclaw/workspace/agents/helios/helios.log
StandardError=append:/home/chad-yi/.openclaw/workspace/agents/helios/helios.log

[Install]
WantedBy=default.target
